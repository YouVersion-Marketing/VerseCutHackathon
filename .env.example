# ── Bible provider ──────────────────────────────────────────────────────────
# 'mock'       — bundled sample data, zero setup (default)
# 'youversion' — YouVersion Platform API (recommended)
# 'api.bible'  — scripture.api.bible
VITE_BIBLE_PROVIDER=youversion

# Default version id shown before the user picks one.
# YouVersion ids: 111=NIV, 3034=BSB, 1=KJV
VITE_BIBLE_DEFAULT_VERSION=111

# ── YouVersion Platform API ───────────────────────────────────────────────────
# The app key is read SERVER-SIDE by the Vite dev proxy (vite.config.ts) and
# injected as the `x-yvp-app-key` header, so it never ships in the client bundle.
# Get a key at https://platform.youversion.com
YV_PLATFORM_API_KEY=

# ── API.Bible (only if VITE_BIBLE_PROVIDER=api.bible) ─────────────────────────
# https://scripture.api.bible
VITE_BIBLE_API_KEY=
